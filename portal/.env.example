# Absolute path to the .ovpn file on the host
OVPN_FILE=/path/to/client.ovpn

# OpenVPN credentials (leave blank if embedded in the .ovpn file via auth-user-pass inline)
VPN_USER=
VPN_PASSWORD=

# Port forward - Admin
HOST_PORT_ADMIN=1234
TARGET_HOST_ADMIN=10.8.0.2
TARGET_PORT_ADMIN=1234

# Port forward - Feed
HOST_PORT_FEED=5678
TARGET_HOST_FEED=10.8.0.2
TARGET_PORT_FEED=5678
