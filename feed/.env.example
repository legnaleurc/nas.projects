# Host to bind on the Docker host.
FEED_HOST=0.0.0.0
# Port to bind on the Docker host.
FEED_PORT=8080

# Path to the YAML config file.
FEED_CONFIG_FILE=/docker/config/feed.yaml
# Path to the Synology Drive API config file (for rehash.sh).
FEED_SYNOLOGY_CONFIG_FILE=/docker/config/synology.yaml
# Directory for the SQLite database.
FEED_DATA_PATH=/docker/data
# Directory to watch (add more volume entries in compose.yaml as needed).
FEED_WATCH_PATH=/volume1
